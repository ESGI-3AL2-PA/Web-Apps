{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "start": "turbo run start",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,md}\"",
    "clean:dist": "npx rimraf dist packages/*/dist apps/*/dist",
    "clean:node": "npx rimraf node_modules packages/*/node_modules apps/*/node_module",
    "clean": "npm run clean:dist && npm run clean:node && npm ci"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3"
  },
  "name": "with-vite-react",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "playwright_testbook"
  ]
}